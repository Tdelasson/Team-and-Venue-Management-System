// 1. Skift til SQLite
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// 2. Bruger-model
model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String // Husk at hashe denne!
  role     String @default("spiller") // admin, træner, spiller, spectator
  
  createdAt DateTime @default(now())
}

model Team {
  id              Int      @id @default(autoincrement())
  name            String
  institute       String
  numberOfPlayers Int
  numberOfFans    Int
  createdAt       DateTime @default(now())
}

